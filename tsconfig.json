{
  "compilerOptions": {
    "noEmit": true,
    "strict": true,
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "allowImportingTsExtensions": true,
    "lib": ["esnext", "dom", "dom.iterable"],
    "types": ["node"]
  },
  "include": ["src", "src/.scripts/build.ts"]
}
